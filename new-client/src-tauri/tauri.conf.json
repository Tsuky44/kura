{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kuma",
  "version": "0.1.0",
  "identifier": "com.mathis.myflix",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Kuma",
        "width": 1280,
        "height": 720,
        "decorations": true,
        "transparent": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "libmpv-2.dll": "libmpv-2.dll",
      "libmpv-wrapper.dll": "libmpv-wrapper.dll",
      "libmpv-wrapper.dylib": "libmpv-wrapper.dylib"
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "",
      "entitlements": "./entitlements.mac.plist"
    }
  }
}
